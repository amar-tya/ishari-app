[
  {
    "label": "Flutter: Run (default device)",
    "command": "flutter run --dart-define-from-file=env/dev.json",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "Flutter: Run Android",
    "command": "flutter run --dart-define-from-file=env/dev.json -d android",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "Flutter: Run iOS",
    "command": "flutter run -d ios",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "Flutter: Build Runner",
    "command": "flutter pub run build_runner build --delete-conflicting-outputs",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "Flutter: Clean",
    "command": "flutter clean && flutter pub get",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "Flutter: Analyze",
    "command": "flutter analyze",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
]
